    <section class="gallery" id="gallery">
        <div class="container">
            <h2>The Cherry Tree Experience</h2>
            <div class="gallery-grid">
                <div class="gallery-item"><img src="https://images.unsplash.com/photo-1514432324607-a09d9b4aefdd?w=400&auto=format" alt="Coffee cup"></div>
