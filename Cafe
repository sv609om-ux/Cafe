    <section class="hero" id="home">
        <div class="container hero-content">
            <div class="rating-badge"><i class="fa-solid fa-star"></i> 4.4 • 7K+ Google Reviews</div>
            <h1>Fresh Coffee, Delicious Desserts & Cozy Ambience in Lucknow</h1>
