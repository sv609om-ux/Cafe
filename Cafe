<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>The Cherry Tree Cafe · Hazratganj, Lucknow</title>
    <!-- Font Awesome 6 (free) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <!-- Google Fonts: modern minimal typography (Inter & Playfair Display for accent) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300..700&family=Playfair+Display:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: "Inter", sans-serif;
            background-color: #fefaf5;
            color: #3e2e23;
            line-height: 1.5;
            scroll-behavior: smooth;
        }

        :root {
            --coffee: #4f3b2c;
            --latte: #d7c3b1;
            --cream: #fef6eb;
            --soft-pink: #f9e1db;
            --brown: #7b5e4b;
            --beige: #f5e8da;
            --shadow: 0 12px 28px rgba(0, 0, 0, 0.05), 0 4px 12px rgba(0, 0, 0, 0.02);
        }

        h1, h2, h3 {
            font-weight: 500;
            letter-spacing: -0.02em;
        }

        h2 {
            font-size: 2.3rem;
            margin-bottom: 0.5rem;
            font-family: "Playfair Display", serif;
            color: var(--coffee);
            position: relative;
            display: inline-block;
        }
        h2:after {
            content: '';
            position: absolute;
            bottom: -10px;
            left: 0;
            width: 70px;
            height: 3px;
            background: #dbaa8c;
            border-radius: 6px;
        }

        .container {
            max-width: 1280px;
            margin: 0 auto;
            padding: 0 24px;
        }

        nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 32px;
            background: rgba(255, 250, 245, 0.85);
            backdrop-filter: blur(6px);
            position: sticky;
            top: 0;
            z-index: 10;
            border-bottom: 1px solid #eedacf;
        }
        .logo {
            font-size: 1.8rem;
            font-weight: 600;
            color: var(--coffee);
            font-family: "Playfair Display", serif;
        }
        .logo i {
            color: #bb7e5e;
            margin-right: 6px;
        }
        .nav-links a {
            text-decoration: none;
            margin-left: 30px;
            color: var(--brown);
            font-weight: 500;
            transition: 0.2s;
            border-bottom: 2px solid transparent;
            padding-bottom: 4px;
        }
        .nav-links a:hover {
            border-bottom-color: #bb7e5e;
            color: #3e2e23;
        }

        .btn {
            display: inline-block;
            background: white;
            padding: 12px 32px;
            border-radius: 40px;
            font-weight: 600;
            text-decoration: none;
            color: var(--coffee);
            box-shadow: var(--shadow);
            transition: 0.2s ease;
            border: 1px solid #edd6c7;
        }
        .btn-primary {
            background: #7b5e4b;
            color: white;
            border: none;
        }
        .btn-primary:hover {
            background: #5f4637;
            transform: scale(1.02);
        }

        .hero {
            background: linear-gradient(0deg, rgba(0, 0, 0, 0.1), rgba(0, 0, 0, 0.2)), url('https://images.unsplash.com/photo-1554118811-1e0d58224f24?w=1200&auto=format') center/cover no-repeat;
            min-height: 85vh;
            display: flex;
            align-items: center;
            color: white;
            text-shadow: 0 2px 15px rgba(0,0,0,0.3);
            border-bottom-left-radius: 3rem;
            border-bottom-right-radius: 3rem;
        }
        .hero-content {
            max-width: 700px;
            padding: 40px 32px;
        }
        .hero h1 {
            font-size: 4rem;
            font-weight: 600;
            line-height: 1.1;
            margin-bottom: 1rem;
            font-family: "Playfair Display", serif;
        }
        .hero p {
            font-size: 1.5rem;
            margin-bottom: 2rem;
            font-weight: 300;
        }
        .hero-buttons .btn {
            margin-right: 16px;
            margin-bottom: 10px;
        }

        .about {
            padding: 90px 0 60px;
            background: var(--cream);
        }
        .about-grid {
            display: flex;
            gap: 50px;
            align-items: center;
            flex-wrap: wrap;
        }
        .about-text {
            flex: 1 1 300px;
            font-size: 1.2rem;
            color: #3e2e23;
        }
        .about-highlight {
            background: #fff3ea;
            padding: 30px;
            border-radius: 32px;
            flex: 0 1 350px;
            box-shadow: var(--shadow);
        }
        .about-highlight i {
            color: #bb7e5e;
            font-size: 2rem;
            margin-bottom: 12px;
        }

        .menu-section {
            padding: 80px 0;
            background: white;
        }
        .menu-category {
            margin-top: 60px;
        }
        .category-title {
            font-size: 2rem;
            font-weight: 500;
            border-left: 8px solid #dbaa8c;
            padding-left: 20px;
            margin-bottom: 40px;
        }
        .menu-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
            gap: 28px;
        }
        .menu-card {
            background: var(--cream);
            border-radius: 24px;
            padding: 24px 18px 18px;
            box-shadow: var(--shadow);
            transition: 0.25s ease;
            border: 1px solid #f1dfd3;
        }
        .menu-card:hover {
            transform: translateY(-6px);
            background: white;
        }
        .menu-card h4 {
            font-size: 1.3rem;
            font-weight: 600;
            margin-bottom: 6px;
        }
        .menu-price {
            font-size: 1.5rem;
            font-weight: 500;
            color: #7b5e4b;
            margin-top: 12px;
        }
        .menu-card i {
            color: #bb7e5e;
            font-size: 1.6rem;
            margin-bottom: 8px;
        }
        .menu-desc {
            font-size: 0.9rem;
            color: #6b5847;
            margin-top: 4px;
        }

        .gallery {
            padding: 80px 0;
            background: var(--beige);
        }
        .gallery-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 20px;
            margin-top: 50px;
        }
        .gallery-item {
            border-radius: 28px;
            overflow: hidden;
            aspect-ratio: 1 / 1;
            box-shadow: var(--shadow);
            transition: 0.4s;
        }
        .gallery-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: 0.4s;
        }
        .gallery-item:hover img {
            transform: scale(1.06);
        }

        .reviews {
            padding: 80px 0;
            background: white;
        }
        .review-grid {
            display: flex;
            flex-wrap: wrap;
            gap: 30px;
            margin-top: 50px;
        }
        .review-card {
            background: #fffaf4;
            border-radius: 30px;
            padding: 30px;
            flex: 1 1 280px;
            box-shadow: var(--shadow);
            border: 1px solid #ffe7db;
        }
        .stars {
            color: #e7a531;
            margin: 15px 0 10px;
            font-size: 1.2rem;
        }
        .reviewer-name {
            font-weight: 600;
            margin-top: 15px;
            color: var(--coffee);
        }
        .review-date {
            font-size: 0.8rem;
            color: #8b7a6b;
        }

        .contact {
            padding: 70px 0 40px;
            background: #392e26;
            color: #f0e3d9;
        }
        .contact .container {
            display: flex;
            flex-wrap: wrap;
            gap: 40px;
        }
        .contact-info {
            flex: 1 1 300px;
        }
        .contact-info i {
            color: #e3b398;
            width: 30px;
        }
        .map {
            flex: 2 1 400px;
            border-radius: 32px;
            overflow: hidden;
            height: 240px;
            box-shadow: 0 8px 18px rgba(0,0,0,0.3);
        }
        .map iframe {
            width: 100%;
            height: 100%;
            border: 0;
        }
        .call-whatsapp {
            margin: 30px 0 20px;
        }
        .social-icon {
            font-size: 1.8rem;
            margin-right: 20px;
            color: #dcc2b0;
        }
        .footer-bottom {
            text-align: center;
            border-top: 1px solid #665546;
            margin-top: 40px;
            padding: 30px 0 10px;
        }
        .rating-badge {
            display: inline-block;
            background: #4CAF50;
            color: white;
            padding: 8px 16px;
            border-radius: 40px;
            font-weight: 600;
            margin-bottom: 20px;
        }

        @media (max-width: 700px) {
            .hero h1 { font-size: 3rem; }
            nav { flex-wrap: wrap; }
            .nav-links a { margin-left: 16px; }
        }
    </style>
</head>
<body>
