                    <div class="menu-card"><i class="fa-solid fa-fries"></i><h4>Peri Peri Potato Wedges</h4><div class="menu-price">₹180</div><div class="menu-desc">Highly recommended </div></div>
                    <div class="menu-card"><i class="fa-solid fa-utensils"></i><h4>Classic Salted Fries</h4><div class="menu-price">₹150</div><div class="menu-desc"></div></div>
                    <div class="menu-card"><i class="fa-solid fa-pizza-slice"></i><h4>Desi Paneer Tikka Pizza</h4><div class="menu-price">₹420</div><div class="menu-desc">Customer favorite </div></div>
                </div>
            </div>

            <div class="menu-category">
                <div class="category-title">Sandwiches & Mains</div>
                <div class="menu-grid">
                    <div class="menu-card"><i class="fa-solid fa-sandwich"></i><h4>Chicken Salami Sandwich</h4><div class="menu-price">₹280</div><div class="menu-desc">Soft and perfect, with chips & salad </div></div>
                    <div class="menu-card"><i class="fa-solid fa-sandwich"></i><h4>BBQ Chicken Burger</h4><div class="menu-price">₹320</div><div class="menu-desc">Really good, with chips and salad </div></div>
